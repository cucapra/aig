digraph AIG {
	rankdir=BT;
	ordering=out;
	node [fontname="Helvetica"];
	edge [fontname="Helvetica"];

	const_false [label="false", shape=box];

	n0 [label="a", shape=box];
	n1 [label="b", shape=box];

	n2 [label="l0", shape=box, style=rounded];
	n3 [label="l1", shape=box, style=rounded];

	n4 [label="AND", shape=circle];
	n5 [label="AND", shape=circle];

	n3 -> n4 [label="left"];
	n0 -> n4 [label="right"];
	n2 -> n5 [label="left", style=dashed];
	n1 -> n5 [label="right", style=dashed];

	n4 -> n2 [label="next"];
	n2 -> n3 [label="next", style=dashed];

	out0 [label="out0", shape=box];
	n2 -> out0;
	out1 [label="out1", shape=box];
	n3 -> out1;
	out2 [label="out2", shape=box];
	n5 -> out2 [style=dashed];
}
