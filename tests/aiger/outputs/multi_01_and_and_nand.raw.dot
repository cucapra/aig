digraph AIG {
	rankdir=BT;
	ordering=out;
	node [fontname="Helvetica"];
	edge [fontname="Helvetica"];

	const_false [label="false", shape=box];

	n0 [label="a", shape=box];
	n1 [label="b", shape=box];


	n2 [label="AND", shape=circle];
	n3 [label="AND", shape=circle];

	n1 -> n2 [label="left"];
	n0 -> n2 [label="right"];
	n1 -> n3 [label="left"];
	n0 -> n3 [label="right"];


	out0 [label="out0", shape=box];
	n2 -> out0;
	out1 [label="out1", shape=box];
	n3 -> out1 [style=dashed];
}
